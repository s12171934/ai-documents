{
  "name": "ai-documents",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter !@s-dante/cli",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "dev:client": "bun --filter @ai-documents/client dev",
    "dev:server": "bun --filter @ai-documents/server dev",
    "dev:cli": "bun --filter @s-dante/cli dev"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
